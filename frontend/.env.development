# ---------------------------------------------------------------
# 本地开发模式 (npm run dev)
# ---------------------------------------------------------------
# API 基础路径：留空，请求走 Vite Proxy 代理
VITE_API_BASE_URL=

# Vite 开发服务器代理目标（仅 npm run dev 时生效）
# 本地后端默认为 http://localhost:8000
# 如需代理到远程服务器，改为例如 http://49.234.185.167:9000
VITE_DEV_PROXY_TARGET=http://localhost:8000
