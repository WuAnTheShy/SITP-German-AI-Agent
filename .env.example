# ==========================================
# 基础运行环境配置
# ==========================================
# 应用运行环境 (例如: production, development, staging)
APP_ENV=production

# ==========================================
# 数据库配置 (Docker Compose 依赖项)
# ==========================================
# PostgreSQL 数据库用户名
POSTGRES_USER=postgres
# PostgreSQL 数据库密码 (请在部署时替换为强密码)
POSTGRES_PASSWORD=your_database_password_here
# PostgreSQL 数据库名称
POSTGRES_DB=sitp_german_ai_agent

# ==========================================
# 认证与系统初始化配置
# ==========================================
# 系统首次初始化时创建的默认管理员用户名
INIT_ADMIN_USERNAME=admin
# 系统首次初始化时的管理员密码 (建议首次登录后立即修改)
INIT_ADMIN_PASSWORD=your_admin_password_here
# 用于生成身份验证 Token (如 JWT) 的加密密钥 (务必替换为至少32位的安全随机字符串)
AUTH_TOKEN_SECRET=your_32_character_super_secret_token_here
# 身份验证 Token 的有效时长（单位：小时）
AUTH_TOKEN_TTL_HOURS=12
# 是否允许使用旧版本的 Token 格式或策略 (通常设为 false 以提高安全性)
ALLOW_LEGACY_TOKENS=false

# ==========================================
# 数据填充与演示账号重置策略
# ==========================================
# 是否在系统启动时自动填充演示数据 (生产环境建议设为 false)
ENABLE_DEMO_SEED=false
# 是否在每次系统启动时强制将管理员密码重置为 INIT_ADMIN_PASSWORD (生产环境必须为 false)
RESET_ADMIN_PASSWORD_ON_STARTUP=false
# 是否在每次系统启动时强制重置演示账号的密码
RESET_DEMO_PASSWORDS_ON_STARTUP=false
# 演示环境教师账号的默认密码
DEMO_TEACHER_PASSWORD=your_demo_teacher_password_here
# 演示环境学生账号的默认密码
DEMO_STUDENT_PASSWORD=your_demo_student_password_here

# ==========================================
# 跨域控制与日志调试
# ==========================================
# 允许的跨域请求来源 (CORS)。
# 若前后端同域部署可留空；跨域时填逗号分隔的域名，例如：http://localhost:5173,https://your-domain.com
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost
# 是否开启大语言模型 (LLM) 调用的调试日志输出，方便排查提示词或接口报错
DEBUG_LLM_LOGS=false

# ==========================================
# 大语言模型 (LLM) 服务商配置
# ==========================================
# 指定当前使用的 LLM 服务商 (此处默认使用阿里云千问)
LLM_PROVIDER=qwen

# --- 阿里云通义千问 (Qwen) 配置 ---
# 填写你的阿里云 DashScope API Key
QWEN_API_KEY=your_qwen_api_key_here
# (可选) 兼容 OpenAI 格式的请求地址
# QWEN_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
# (可选) 指定具体的千问模型版本
# LLM_MODEL=qwen3.5-plus

# --- 备选：本地 LM Studio 配置 (可选) ---
# 若 LLM_PROVIDER=lmstudio，则启用以下配置
# LLM_PROVIDER=lmstudio
# 本地 LM Studio 服务的 API 基础地址 (Docker 环境下通常需要使用 host.docker.internal 访问宿主机)
# LMSTUDIO_BASE_URL=http://host.docker.internal:1234
# 在 LM Studio 中加载的具体模型名称
# LMSTUDIO_MODEL=qwen2.5-7b-instruct
# LM Studio 的 API 密钥 (一般本地调试时可留空)
# LMSTUDIO_API_KEY=your_lmstudio_api_key_here